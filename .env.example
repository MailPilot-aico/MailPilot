# =========================================================
#  MailPilot — Vorlage für Umgebungsvariablen
#  Kopiere diese Datei zu ".env" und trage deine Schlüssel ein.
#  (Die echte .env wird NICHT committet.)
#
#  Für die Live-Seite die Werte stattdessen im Netlify-Dashboard
#  setzen: Site settings → Environment variables.
# =========================================================

# Stripe – Geheimschlüssel (NUR serverseitig, niemals ins Frontend!)
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe – veröffentlichbarer Schlüssel (darf öffentlich sein)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe – Preis-IDs (price_…). Im Test- und Live-Modus unterschiedlich!
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx

# (Bereits genutzt) Anthropic-Schlüssel für die KI-Funktion
ANTHROPIC_API_KEY=sk-ant-xxx

# Supabase
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx        # öffentlich
# SUPABASE_SERVICE_ROLE_KEY=                 # geheim, nur serverseitig (optional, später)
